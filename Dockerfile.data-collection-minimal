# =============================================================================
# Dockerfile.data-collection-minimal  —  fully standalone build
# -----------------------------------------------------------------------------
# Purpose: build a minimal image needed only for data "collection (teleoperation recording)",
#          from scratch, without depending on the inference base (groot-n16-inference).
#
# Why the inference image is not needed:
#   - Data collection does no neural-network inference. It only records leader->follower motion
#     together with cameras/joints via `lerobot-record`. No GR00T model weights/ONNX/inference server needed.
#
# How torch is obtained on aarch64 (Jetson Thor) — verified source:
#   Isaac-GR00T scripts/deployment/thor/{install_deps.sh, pyproject.toml}
#   (commit 5dc80c4); the facts confirmed there are reflected as-is.
#     - torch wheel index: https://pypi.jetson-ai-lab.io/sbsa/cu130/+simple
#     - pins: torch==2.10.0 torchvision==0.25.0 torchcodec==0.10.0 triton==3.5.0
#     - the torch wheel requires NVPL LAPACK/BLAS (libnvpl-*) from the system.
#     - torchcodec (video decode/encode) is source-built against the system FFmpeg.
#   -> i.e. installing just the above packages (without cloning the whole GR00T repo) is enough to run lerobot-record.
#
# lerobot pin (important): PyPI lerobot==0.5.1 lacks so101_follower. Install the git commit
#   pinned by Isaac-GR00T (c75455a). Use --no-deps to avoid overwriting torch.
#
# Build (on the device = Jetson Thor aarch64):
#   docker build -f Dockerfile.data-collection-minimal \
#     -t lerobot-data-collection:latest .
# =============================================================================

# Public NVIDIA CUDA image (Docker Hub): CUDA toolkit (incl. CUPTI/headers) + cuDNN bundle.
# The arm64/sbsa 13.0.2 variant is verified to run on Jetson Thor (L4T r38.x / JetPack 7).
# It resolves in one shot the missing libraries (libcudnn.so.9, libcupti.so.13) that the plain
# CUDA runtime base hit, plus the missing headers for the torchcodec source build.
FROM nvidia/cuda:13.0.2-cudnn-devel-ubuntu24.04

ENV NVIDIA_DRIVER_CAPABILITIES=graphics,utility,compute
ENV DEBIAN_FRONTEND=noninteractive
ENV DOCKER_CONTAINER=1
ENV UV_PROJECT_ENVIRONMENT=/opt/gr00t-venv

# torch pins (managed here in one place). Matches install_deps.sh / thor pyproject.toml.
ARG TORCH_VERSION=2.10.0
ARG TORCHVISION_VERSION=0.25.0
ARG TORCHCODEC_VERSION=0.10.0
ARG TRITON_VERSION=3.5.0
ARG JETSON_INDEX=https://pypi.jetson-ai-lab.io/sbsa/cu130/+simple
ARG LEROBOT_COMMIT=c75455a6de5c818fa1bb69fb2d92423e86c70475

# -----------------------------------------------------------------------------
# 1) OS packages
#    - python3.12 / venv
#    - git (lerobot git install), curl (uv install)
#    - FFmpeg dev libraries: required for the torchcodec source build (same as install_deps.sh)
#    - after the NVIDIA CUDA apt repo is registered, NVPL LAPACK/BLAS: required by the aarch64 torch wheel
#    - camera (opencv) runtime: libGL/glib
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3 python3-venv python3-dev \
        git git-lfs curl ca-certificates \
        build-essential cmake pkg-config pybind11-dev \
        ffmpeg \
        libavdevice-dev libavfilter-dev libavformat-dev libavcodec-dev \
        libavutil-dev libswresample-dev libswscale-dev \
        libgl1 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && git lfs install

# NVPL LAPACK/BLAS — runtime libraries linked by the Jetson torch wheel.
# The base nvidia/cuda image already configures the CUDA apt repo + keyring (Signed-By=cuda-archive-keyring.gpg),
# so we install directly. Reinstalling cuda-keyring would add a conflicting source entry for the same
# repo URI (Signed-By conflict) and break apt (INSTALL_ERROR).
RUN apt-get update && apt-get install -y --no-install-recommends \
        libnvpl-lapack0 libnvpl-blas0 && \
    rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# 2) uv + Python 3.12 virtual environment
# -----------------------------------------------------------------------------
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:/opt/gr00t-venv/bin:/usr/local/cuda/bin:$PATH"
RUN uv venv /opt/gr00t-venv --python 3.12

ENV VIRTUAL_ENV=/opt/gr00t-venv
ENV CUDA_HOME=/usr/local/cuda-13.0
ENV CUDA_PATH=/usr/local/cuda-13.0

# -----------------------------------------------------------------------------
# 3) PyTorch (aarch64/CUDA13) — installed from the Jetson AI Lab index with verified pins
#    This is the core of the from-scratch build. This index provides NVIDIA pre-built torch.
# -----------------------------------------------------------------------------
RUN uv pip install --python /opt/gr00t-venv/bin/python \
        --index-url "${JETSON_INDEX}" \
        "torch==${TORCH_VERSION}" \
        "torchvision==${TORCHVISION_VERSION}" \
        "triton==${TRITON_VERSION}"

# cuDSS — the Jetson torch wheel links libcudss.so.0, which is not in the CUDA base image and
# is not pulled in as a pip dependency by the Jetson torch wheel. Same as the proven groot1.7
# com.groot.docker-build: install nvidia-cudss-cu13 and expose its lib path.
RUN uv pip install --python /opt/gr00t-venv/bin/python nvidia-cudss-cu13

# site-packages paths (used in the torchcodec build/runtime LD_LIBRARY_PATH) — includes cuDSS/cuDNN
ENV LD_LIBRARY_PATH="/opt/gr00t-venv/lib/python3.12/site-packages/torch/lib:/opt/gr00t-venv/lib/python3.12/site-packages/nvidia/cu13/lib:/opt/gr00t-venv/lib/python3.12/site-packages/nvidia/cudss/lib:/opt/gr00t-venv/lib/python3.12/site-packages/nvidia/cudnn/lib:/usr/local/cuda-13.0/lib64"

# cuDNN + CUPTI are provided by the cudnn-devel base image (no extra install needed).

# -----------------------------------------------------------------------------
# 4) torchcodec — source-built against the system FFmpeg (same approach as install_deps.sh)
#    Needed by lerobot's video decode/encode path.
# -----------------------------------------------------------------------------
RUN uv pip install --python /opt/gr00t-venv/bin/python setuptools && \
    NVIDIA_LIB_DIRS="$(find /opt/gr00t-venv/lib/python3.12/site-packages/nvidia -name lib -type d 2>/dev/null | tr '\n' ':')" && \
    export LD_LIBRARY_PATH="/opt/gr00t-venv/lib/python3.12/site-packages/torch/lib:${NVIDIA_LIB_DIRS}${LD_LIBRARY_PATH}" && \
    export CPATH="${CUDA_HOME}/include:${CPATH:-}" && \
    git clone --depth 1 --branch "v${TORCHCODEC_VERSION}" https://github.com/pytorch/torchcodec.git /tmp/torchcodec && \
    cd /tmp/torchcodec && \
    I_CONFIRM_THIS_IS_NOT_A_LICENSE_VIOLATION=1 \
      uv pip install --python /opt/gr00t-venv/bin/python . --no-build-isolation && \
    cd / && rm -rf /tmp/torchcodec

# -----------------------------------------------------------------------------
# 5) lerobot + robot/camera/IPC dependencies
#    - lerobot: the commit that includes so101_follower, --no-deps (prevents overwriting torch)
#    - install only the lightweight packages lerobot actually imports (normal install)
#    - feetech/pyserial/opencv/awsiotsdk also --no-deps to protect torch
# -----------------------------------------------------------------------------
RUN uv pip install --python /opt/gr00t-venv/bin/python \
        draccus==0.10.0 deepdiff pyyaml einops numpy==1.26.4 boto3 rerun-sdk \
        datasets diffusers "huggingface-hub[hf-transfer,cli]" accelerate \
        pynput wandb gymnasium "imageio[ffmpeg]" termcolor safetensors av jsonlines && \
    uv pip install --python /opt/gr00t-venv/bin/python --no-deps \
        feetech-servo-sdk pyserial opencv-python-headless awsiotsdk && \
    uv pip install --python /opt/gr00t-venv/bin/python --no-deps \
        "lerobot @ git+https://github.com/huggingface/lerobot.git@${LEROBOT_COMMIT}"

# -----------------------------------------------------------------------------
# 6) Verify: does the lerobot-record entry point exist?
# -----------------------------------------------------------------------------
RUN test -x /opt/gr00t-venv/bin/lerobot-record && \
    echo "OK: lerobot-record present" || \
    (echo "ERROR: lerobot-record missing" && exit 1)

# collect.py injects the command at docker run via -c "lerobot-record ...", so bash is the entry point.
# checkov:skip=CKV_DOCKER_3: lerobot-record must run as root to access the robot arms
#   (/dev/ttyACM*), cameras (/dev/cam_*) and the NVIDIA runtime; a non-root user would break device access.
HEALTHCHECK CMD test -x /opt/gr00t-venv/bin/lerobot-record || exit 1
WORKDIR /workspace
ENTRYPOINT ["/bin/bash"]
